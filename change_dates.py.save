
import datetime

commits = subprocess.check_output(
    ["git", "rev-list", "--reverse", "HEAD"],
    text=True
).splitlines()

start = datetime.datetime(2026, 6, 15, 10, 0)
end = datetime.datetime(2026, 7, 11, 20, 0)

total = len(commits)

dates = {"2026-06-15 10:15:00",
"2026-06-16 14:20:00",
"2026-06-17 18:40:00",
"2026-06-18 11:30:00",
"2026-06-19 16:45:00",
"2026-06-20 13:15:00",
"2026-06-21 19:10:00",
"2026-06-22 09:50:00",
"2026-06-23 15:30:00",
"2026-06-24 20:10:00",
"2026-06-25 12:40:00",
"2026-06-27 17:25:00",
"2026-06-29 14:00:00",
"2026-06-30 18:15:00",
"2026-07-02 10:45:00",
"2026-07-04 16:20:00",
"2026-07-06 12:30:00",
"2026-07-08 18:50:00",
"2026-07-10 15:15:00",
"2026-07-11 20:00:00"}

for i, commit in enumerate(commits):
    moment = start + (end - start) * i / (total - 1)
    dates[commit] = moment.strftime("%Y-%m-%d %H:%M:%S")

with open("env_filter.sh", "w") as f:
    f.write("#!/bin/sh\n")
    f.write("case \"$GIT_COMMIT\" in\n")

    for commit, date in dates.items():
        f.write(f"{commit})\n")
        f.write(f"export GIT_AUTHOR_DATE='{date}'\n")
        f.write(f"export GIT_COMMITTER_DATE='{date}'\n")
        f.write(";;\n")

    f.w
